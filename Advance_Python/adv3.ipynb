    "## Closures -> Function inside a function\n",
    "\n",
    "def main_welcome():\n",
    "    msg = \"Welcome\"\n",
    "    def sub_welcome():\n",
    "        print(\"Welcome Tada!\")\n",
    "        print(msg)\n",
    "        print(\"Good Morning!\")\n",
    "    return sub_welcome()"
   ]
