    "### Decorator\n",
    "def my_decorator(func):\n",
    "    def wrapper():\n",
    "        print(\"Something before the function runs\")\n",
    "        func()\n",
    "        print(\"Something after the function runs\")\n",
    "    return wrapper\n",
    "\n",
    "\n",
    "@my_decorator #creating decorator we need this\n",
    "def say_hello(): #function given as a parameter\n",
    "    print(\"Hello!\")\n",
    "\n",
    "say_hello()"
   ]
  },
