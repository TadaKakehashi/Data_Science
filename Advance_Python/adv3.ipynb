   "source": [
    "#### What is wrapper in a Decorator?\n",
    "A wrapper is a function inside a decorator that wraps the original function and adds extra behavior before or after it runs.\n",
    "It basically controls how the original function executes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "2b83742c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Before running the function\n",
      "Hello!\n",
      "After running the function\n"
     ]
    }
   ],
   "source": [
    "def my_decorator(func):\n",
    "    def wrapper():\n",
    "        print(\"Before running the function\")\n",
    "        func()\n",
    "        print(\"After running the function\")\n",
    "    return wrapper\n",
    "\n",
    "\n",
    "@my_decorator\n",
    "def greet():\n",
    "    print(\"Hello!\")\n",
    "\n",
    "greet()"
   ]
